{
  "description": "Semicolon to special characters",
  "manipulators": [
    {
      "description": "semicolon = ;(click) | hyper(hold)",
      "from": {
        "key_code": "semicolon",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "fn",
          "modifiers": ["right_command", "right_control", "right_option"]
        }
      ],
      "to_if_alone": [
        {
          "key_code": "semicolon"
        }
      ],
      "type": "basic"
    },

    {
      "description": "; + g= % => jump to matching pair",
      "from": {
        "key_code": "g",
        "modifiers": {
          "mandatory": ["right_command", "right_control", "fn", "right_option"]
        }
      },
      "to": [
        {
          "key_code": "5",
          "modifiers": ["left_shift"]
        }
      ],
      "type": "basic"
    },

    {
